/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */

class Solution {

    public int sumRootToLeaf(TreeNode root) {
        return dfs(root, 0);
    }

    private int dfs(TreeNode node, int currentValue) {
        if (node == null) {
            return 0;
        }

        /*
         * Multiply by 2 (shift left in binary)
         * then add current node's value (0 or 1).
         */
        currentValue = currentValue * 2 + node.val;

        // If this is a leaf node (no left and right children)
        if (node.left == null && node.right == null) {
            return currentValue;
        }

        int leftSum = dfs(node.left, currentValue);
        int rightSum = dfs(node.right, currentValue);

        return leftSum + rightSum;
    }
}
