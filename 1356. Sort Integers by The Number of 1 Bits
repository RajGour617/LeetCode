class Solution {
    public int[] sortByBits(int[] arr) {
        int n = arr.length;

        for (int i = 0; i < n - 1; i++) {
            for (int j = i + 1; j < n; j++) {

                int bitsI = Integer.bitCount(arr[i]);
                int bitsJ = Integer.bitCount(arr[j]);

                // Compare by bit count
                if (bitsI > bitsJ || (bitsI == bitsJ && arr[i] > arr[j])) {
                    int temp = arr[i];
                    arr[i] = arr[j];
                    arr[j] = temp;
                }
            }
        }

        return arr;
    }
}
