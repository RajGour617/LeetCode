# Approach 1 

class Solution {
    public boolean hasAlternatingBits(int n) {
        String binary = Integer.toBinaryString(n);
        char[] arr = binary.toCharArray();

        for (int i = 1; i < arr.length; i++) {
            if (arr[i] == arr[i - 1]) {
                return false;
            }
        }
        return true;
    }
}

# Approach 2

class Solution {
    public boolean hasAlternatingBits(int n) {
        String binary = Integer.toBinaryString(n);
        char[] arr = binary.toCharArray();

        if (arr[0] == '0') {
            for (int i = 0; i < arr.length; i++) {
                if ((i % 2 == 0) && (arr[i] != '0'))
                    return false;
                if ((i % 2 != 0) && (arr[i] != '1'))
                    return false;
            }
        } else {
            for (int i = 0; i < arr.length; i++) {
                if ((i % 2 == 0) && (arr[i] != '1'))
                    return false;
                if ((i % 2 != 0) && (arr[i] != '0'))
                    return false;
            }
        }
        return true;
    }
}
