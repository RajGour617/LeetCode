class Solution {
    public int minAbsoluteDifference(int[] nums) {

        int last1 = -1;
        int last2 = -1;

        int res = Integer.MAX_VALUE;

        for (int i = 0; i < nums.length; i++) {

            if (nums[i] == 1) {
                last1 = i;
                if (last2 != -1) {
                    res = Math.min(res, Math.abs(last1 - last2));
                }
            }

            if (nums[i] == 2) {
                last2 = i;
                if (last1 != -1) {
                    res = Math.min(res, Math.abs(last1 - last2));
                }
            }
        }

        return res == Integer.MAX_VALUE ? -1 : res;
    }
}
