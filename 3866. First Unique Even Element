class Solution {
    public int firstUniqueEven(int[] nums) {
        int[] freq = new int[101];

        for (int n : nums) {
            freq[n]++;
        }

        for (int n : nums) {
            if (n % 2 == 0 && freq[n] == 1) {
                return n;
            }
        }

        return -1;
    }
}
