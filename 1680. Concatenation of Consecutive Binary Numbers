class Solution {
    public int concatenatedBinary(int n) {

        long result = 0;
        int mod = 1_000_000_007;
        int bitLength = 0;

        for (int i = 1; i <= n; i++) {

            // if i is power of 2 → increase bit length
            if ((i & (i - 1)) == 0) {
                bitLength++;
            }

            // shift left and append i
            result = ((result << bitLength) + i) % mod;
        }

        return (int) result;
    }
}
